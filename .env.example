# ==============================================
# EduVision Production Environment Variables
# Copy this file to .env.production and fill in!
# DO NOT commit .env.production to git!
# ==============================================

# Django
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=YOUR_SERVER_IP,yourdomain.com

# Database (PostgreSQL inside Docker)
DB_NAME=eduvision
DB_USER=eduvision_user
DB_PASSWORD=change-this-strong-password
DB_HOST=db
DB_PORT=5432

# Redis (inside Docker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Django settings module
DJANGO_SETTINGS_MODULE=eduvision.settings

# Frontend public URLs (replace with your server IP or domain)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP
NEXT_PUBLIC_WS_URL=ws://YOUR_SERVER_IP
